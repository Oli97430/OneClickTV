{
  "name": "oneclicktv",
  "private": true,
  "version": "1.0.0",
  "description": "OneClickTV — Chaînes TV francophones",
  "author": "OneClickTV",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "concurrently -k \"npm run dev\" \"wait-on http://localhost:8080 && electron .\"",
    "build:desktop": "vite build && electron-builder",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "build:android": "vite build && npx cap sync android",
    "apk:debug": "cd android && gradlew.bat assembleDebug",
    "apk:release": "cd android && gradlew.bat assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.2",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "astral-regex": "^2.0.0",
    "axios": "^1.7.9",
    "hls.js": "^1.5.21",
    "lucide-react": "^0.468.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.0.0",
    "vite": "^7.2.4",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.oneclicktv.app",
    "productName": "OneClickTV",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "electron",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.entertainment"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
